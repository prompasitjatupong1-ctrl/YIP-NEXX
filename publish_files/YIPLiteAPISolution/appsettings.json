  // *** HTML Content Security Config ***
  "HtmlContent": {
    "AllowedIframeSchemes": [ "https" ], // อนุญาตเฉพาะการฝัง iframe จากแหล่งที่ใช้ HTTPS เท่านั้น
    "AllowedIframeHosts": [ "localhost" ], // URL ที่อนุญาตเให้ฝัง iframe
    "AllowedIframePorts": [ 8443 ], // พอร์ตที่อนุญาตให้ฝัง iframe
    "AllowedIframePathPrefixes": [ "/content/" ], // อนุญาตเฉพาะการฝัง iframe ที่มี path เริ่มต้นด้วย /content/
    "AllowPrivateIp": true // อนุญาตให้ฝัง iframe จาก IP ภายใน (เช่น 192.168.x.x, 10.x.x.x) ถ้าเป็น true แต่ถ้าไม่ต้องการให้ฝังจาก IP ภายในเลยให้ตั้งเป็น false
  },

  // *** Password Policy Config ***
