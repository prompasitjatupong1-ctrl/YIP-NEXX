{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "jwt": {
    "key": "YipH6#$ld9&hd90JDhfdf&*dF0Gjk$d8f0dFgR$d*9"
  },

  "AppEndpoints": {
    // ตั้งค่า URL สำหรับ Web
    "Web": {
      "Scheme": "https", // ใช้ HTTPS สำหรับเว็บแอปพลิเคชัน
      "Host": "localhost", // ชื่อโฮสต์ที่แอปพลิเคชันจะฟัง (สามารถเปลี่ยนเป็นชื่อโดเมนหรือ IP ได้)
      "Port": 8443 // พอร์ตที่แอปพลิเคชันจะฟัง (ใช้พอร์ตที่ไม่ชนกับบริการอื่น เช่น 80 หรือ 443) 8443,7111
    },
    // ตั้งค่า URL สำหรับ API
    "Api": {
      "Scheme": "https", // ใช้ HTTPS สำหรับ API เพื่อความปลอดภัย
      "Host": "localhost", // ชื่อโฮสต์ที่ API จะฟัง (สามารถเปลี่ยนเป็นชื่อโดเมนหรือ IP ได้)
      "Port": 8444, // พอร์ตที่ API จะฟัง (ใช้พอร์ตที่ไม่ชนกับบริการอื่น เช่น 80 หรือ 443) 8444,7073

      "UseIisRewriteProxy": false,
      "RewritePrefix": "/api"
    }
  },

  "Csp": {
    "ReportOnly": false,
    "ConnectSrc": [
      "https://localhost:8444", // 8444,7073
      "https://localhost:8443", // 8443,7111
      "https://login.microsoftonline.com",
      "https://graph.microsoft.com"
    ],
    "FrameSrc": [
      "https://accounts.google.com",
      "https://login.microsoftonline.com"
    ],
    "StyleSrc": [
      "https://fonts.googleapis.com",
      "https://accounts.google.com"
    ],
    "ScriptSrc": [
      "https://accounts.google.com",
      "https://www.gstatic.com"
    ],
    "ImgSrc": [
      "https://accounts.google.com",
      "https://*.googleusercontent.com"
    ]
  },

  // ตั้งค่า URL และข้อมูลการเข้าสู่ระบบสำหรับ SSRS
  "SSRS": {
    "Scheme": "http", // SSRS มักจะใช้ HTTP
    "Host": "sbs-rungsoso-nb", // ชื่อโฮสต์ของเซิร์ฟเวอร์ที่ติดตั้ง SSRS
    "Port": 80, // พอร์ตที่ SSRS ใช้ (โดยปกติคือ 80 หรือ 443)
    "ReportServerPath": "/ReportServer", // เส้นทางสำหรับ ReportServer
    "Username": "xxx", // ชื่อผู้ใช้สำหรับการเข้าสู่ระบบ SSRS
    "Password": "yyy" // รหัสผ่านสำหรับการเข้าสู่ระบบ SSRS
  },

  // ตั้งค่าเกี่ยวกับการจัดการเซสชันและโทเค็นสำหรับการเข้าสู่ระบบ
  "AuthSession": {
    "IdleTimeoutMinutes": 30,
    "RenewIntervalMinutes": 5
  },

  // ตั้งค่าเกี่ยวกับการจัดการโทเค็นสำหรับการเข้าสู่ระบบ SSRS
  "SsrsAuth": {
    "TtlSeconds": 1800, // ระยะเวลาที่โทเค็นการเข้าสู่ระบบ SSRS มีอายุ (ในวินาที) 1800=30 นาที
    "PingIntervalSeconds": 60 // ระยะเวลาที่จะทำการ ping เพื่อตรวจสอบว่าโทเค็นยังใช้งานได้อยู่หรือไม่ (ในวินาที)
  },

  "AuthCookie": {
    "Name": "nexxfs_auth"
  },

  "ReverseProxy": {
    "Routes": {
      "ssrsRoute": {
        "ClusterId": "ssrsCluster",
        "Match": { "Path": "/ssrs/{htmlId:int}/{**catch-all}" }
      },
      "ssrsQueryRoute": {
        "ClusterId": "ssrsCluster",
        "Match": { "Path": "/ssrs/{htmlId:int}" }
      },
      "reportServerRoute": {
        "ClusterId": "ssrsCluster",
        "Match": { "Path": "/ReportServer/{**catch-all}" }
      }
    },
    "Clusters": {
      "ssrsCluster": {
        "Destinations": {
          "d1": {
            "Address": "http://placeholder/" // ไม่ต้องแก้ค่าเพราะจะถูกแทนที่ด้วย URL ของ SSRS ในโค้ด
          }
        }
      }
    }
  }
}
